{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "dependencyDashboard": true,
  "timezone": "Europe/Moscow",
  "schedule": ["before 4am on monday"],
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "pin",
  "labels": ["dependency"],
  "commitMessagePrefix": "deps:",
  "postUpdateOptions": [
    "gomodTidy",
    "npmDedupe"
  ],
  "vulnerabilityAlerts": {
    "minimumReleaseAge": null,
    "schedule": ["at any time"],
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Group ansible pip + collections",
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["ansible"],
      "commitMessagePrefix": "deps(ansible):",
      "groupName": "ansible non-major"
    },
    {
      "description": "Group npm non-major",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["nodejs"],
      "commitMessagePrefix": "deps(node):",
      "groupName": "npm non-major"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "addLabels": ["github-actions"],
      "commitMessagePrefix": "deps(actions):",
      "groupName": "GitHub Actions non-major"
    },
    {
      "description": "Group Docker and Compose",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "addLabels": ["docker"],
      "commitMessagePrefix": "deps(docker):",
      "groupName": "Docker non-major"
    },
    {
      "description": "Group Go",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["go"],
      "commitMessagePrefix": "deps(go):",
      "groupName": "Go non-major"
    },
    {
      "description": "Separate major updates and quarantine for longer",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update ansible-core pip package in deploy workflow. Matches: pip install --user ansible-core==2.20.2",
      "fileMatch": ["workflows/generic-deploy\\.yml$"],
      "matchStrings": [
        "pip install --user (?<depName>ansible-core)==(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Update ansible-galaxy collections in deploy workflow. Matches: ansible-galaxy collection install community.general:12.3.0...",
      "fileMatch": ["workflows/generic-deploy\\.yml$"],
      "matchStrings": [
        "(?<depName>[\\w.-]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "galaxy-collection"
    }
  ]
}
