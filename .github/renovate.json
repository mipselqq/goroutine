{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "dependencyDashboard": true,
  "timezone": "Europe/Moscow",
  "schedule": ["before 4am on monday"],
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "pin",
  "labels": ["dependency"],
  "commitMessagePrefix": "deps:",
  "postUpdateOptions": [
    "gomodTidy",
    "npmDedupe"
  ],
  "vulnerabilityAlerts": {
    "minimumReleaseAge": null,
    "schedule": ["at any time"],
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Group Ansible",
      "matchDepTypes": ["ansible"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["ansible"],
      "commitMessagePrefix": "deps(ansible):",
      "groupName": "Ansible non-major"
    },
    {
      "description": "Group Tools",
      "matchDepTypes": ["tools"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["tools"],
      "commitMessagePrefix": "deps(tools):",
      "groupName": "Tools non-major"
    },
    {
      "description": "Group Npm",
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "addLabels": ["npm"],
      "commitMessagePrefix": "deps(npm):",
      "groupName": "Npm non-major"
    },
    {
      "description": "Group Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "addLabels": ["workflows"],
      "commitMessagePrefix": "deps(workflows):",
      "groupName": "Workflows non-major"
    },
    {
      "description": "Group Docker",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "addLabels": ["docker"],
      "commitMessagePrefix": "deps(docker):",
      "groupName": "Docker non-major"
    },
    {
      "description": "Group Go",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["go"],
      "commitMessagePrefix": "deps(go):",
      "groupName": "Go non-major"
    },
    {
      "description": "Separate major updates and quarantine for longer",
      "matchUpdateTypes": ["major"],
      "groupName": null,
      "minimumReleaseAge": "7 days"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update ansible-core in deploy workflow",
      "managerFilePatterns": ["/workflows/generic-deploy\\.yml$/"],
      "matchStrings": [
        "(?<depName>ansible-core)==(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "pypi",
      "depTypeTemplate": "ansible"
    },
    {
      "customType": "regex",
      "description": "Update Ansible Galaxy collections in deploy workflow",
      "managerFilePatterns": ["/workflows/generic-deploy\\.yml$/"],
      "matchStringsStrategy": "recursive",
      "matchStrings": [
        "ansible-galaxy collection install .+",
        "(?<depName>[\\w.-]+):(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "galaxy-collection",
      "depTypeTemplate": "ansible"
    },
    {
      "customType": "regex",
      "description": "Update Go tools in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "go install (?<depName>\\S+)@(?<currentValue>\\S+)"
      ],
      "packageNameTemplate": "{{{replace '/cmd/.*$' '' depName}}}",
      "datasourceTemplate": "go",
      "depTypeTemplate": "tools"
    },
    {
      "customType": "regex",
      "description": "Update npm tools in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "npm install -D (?<depName>\\S+)@(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "npm"
    }
  ]
}
